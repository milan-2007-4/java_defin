import java.util.LinkedList;
public class 48linklist
{
    public static void main(String[] args) {
        LinkedList<String> list = new LinkedList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Mango");
        list.add(1,"Orange");
        list.remove("Banana");
        for(String item : list)
        {
            System.out.println(item);
        }
    }
}
/*
Apple
Orange
Mango
*/
